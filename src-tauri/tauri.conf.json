{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Journal",
  "version": "0.1.0",
  "identifier": "com.fewgtsg.journal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Journal",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ],
        "section": "utils",
        "priority": "optional"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
